{
	"compilerOptions": {
		"allowImportingTsExtensions": true,
		"lib": ["ES2023"],
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"noEmit": true,
		"noImplicitReturns": true,
		"noUncheckedIndexedAccess": true,
		"skipLibCheck": true,
		"strict": true,
		"target": "ES2022",
		"types": ["bun-types", "node"]
	},
	"include": ["src", "scripts", "test", "oxlint.config.ts"]
}
